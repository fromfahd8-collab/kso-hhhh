<Window x:Class="KSO.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="حول البرنامج" Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Icon="app.ico"
        ResizeMode="NoResize">
    <TabControl>
        <TabItem Header="التعريف">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <TextBlock Text="برمجة: عبد الله و عبد الرحمن هاني [ KSO ]" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="22">
                        <Run Text="الإصدار: Ultra V1.0 PRO" FontWeight="Bold" /><LineBreak/>
                        <Run Text="مصمم لمساعدة الطلاب في المذاكرة وتحميل الفيديوهات والملفات بسرعة فائقة." /><LineBreak/><LineBreak/>
                        <Run Text="المميزات الكاملة:" FontWeight="Bold" /><LineBreak/>
                        <Run Text="• تحميل متعدد الأجزاء حتى 200 جزء مع استئناف تلقائي." /><LineBreak/>
                        <Run Text="• اختبار سرعة النت وتعديل الخيوط ديناميكياً." /><LineBreak/>
                        <Run Text="• جدولة التحميلات وتحديد السرعة." /><LineBreak/>
                        <Run Text="• محول صيغ مدمج MP3، 720p، قص 30 ثانية، ضغط باستخدام FFmpeg." /><LineBreak/>
                        <Run Text="• لقط الروابط تلقائياً من المتصفح المدمج." /><LineBreak/>
                        <Run Text="• تبويب المذاكرة للبحث عن كورسات وإنشاء مجلدات." /><LineBreak/>
                        <Run Text="• سجل التحميلات والبحث فيها وتصدير CSV." /><LineBreak/>
                        <Run Text="• وضع خفي وكلمة سر لحماية البرنامج." /><LineBreak/>
                        <Run Text="• ضغط تلقائي للفيديوهات لتوفير المساحة." /><LineBreak/><LineBreak/>
                        <Run Text="مقارنة شاملة:" FontWeight="Bold" /><LineBreak/>
                        <Run Text="• IDM: مدفوع، سرعة جيدة، لكن لا يدعم التحميل المتعدد الأجزاء بكفاءة عالية." /><LineBreak/>
                        <Run Text="• Snap Tube: مجاني، محدود في الميزات والسرعة." /><LineBreak/>
                        <Run Text="• KSO: مجاني، مفتوح المصدر، يدعم التحميل فائق السرعة مع إدارة ذكية للخيوط، وميزات متقدمة." />
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="الاختصارات">
            <ListView x:Name="lvShortcuts" BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="الاختصار" DisplayMemberBinding="{Binding Key}" Width="150"/>
                        <GridViewColumn Header="الوظيفة" DisplayMemberBinding="{Binding Description}" Width="470"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </TabItem>
    </TabControl>
</Window>